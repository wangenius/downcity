{
  "name": "downcity",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": {
    "packages": [
      "console-ui",
      "package",
      "examples/*"
    ]
  },
  "scripts": {
    "build": "bash ./scripts/build.sh",
    "build:extension": "bash ./scripts/extbuild.sh",
    "ui": "npm --prefix ./console-ui run dev",
    "dev": "cd examples/server-agent && downcity agent start",
    "cli": "bun run examples/cli-interactive/src/index.ts",
    "publish": "./scripts/publish.sh"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git"
  },
  "homepage": "https://downcity.ai"
}

{
  "name": "downcity-workspace",
  "private": true,
  "version": "1.1.5",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "help": "node ./scripts/help.mjs",
    "build": "bash ./scripts/build.sh all",
    "build:all": "bash ./scripts/build.sh all",
    "build:type": "pnpm -C packages/type build",
    "build:agent": "pnpm -C packages/type build && pnpm -C packages/agent build",
    "build:city": "pnpm -C packages/type build && pnpm -C packages/city build",
    "build:services": "pnpm -C packages/services build",
    "build:plugins": "pnpm -C packages/plugins build",
    "build:cli": "pnpm -C cli/city build && pnpm -C cli/studio build && pnpm -C products/console build && pnpm -C cli/downcity build",
    "build:city-command": "pnpm -C cli/city build",
    "build:studio-command": "pnpm -C cli/studio build",
    "build:homepage": "pnpm -C homepage build",
    "build:extension": "bash ./scripts/extbuild.sh",
    "build:extension:release": "bash ./scripts/extbuild.sh --release",
    "install:ws": "pnpm install",
    "dev:console": "pnpm -C products/console dev",
    "dev:cli": "pnpm -C cli/city dev",
    "dev:city-command": "pnpm -C cli/city dev",
    "dev:studio-command": "pnpm -C cli/studio dev",
    "dev:agent": "pnpm -C packages/agent dev",
    "dev:plugins": "pnpm -C packages/plugins dev",
    "dev:ui-sdk": "pnpm -C packages/ui dev",
    "dev:homepage": "pnpm -C homepage dev",
    "homepage": "pnpm -C homepage dev",
    "console": "npm --prefix ./products/console run dev",
    "publish": "./scripts/publish.sh",
    "publish:ui": "./scripts/publish-ui.sh",
    "typecheck": "pnpm -C packages/type typecheck && pnpm -C packages/agent typecheck && pnpm -C packages/city typecheck && pnpm -C packages/services typecheck && pnpm -C packages/plugins typecheck && pnpm -C cli/city typecheck && pnpm -C cli/studio typecheck && pnpm -C cli/downcity typecheck && pnpm -C cities/node typecheck && pnpm -C cities/edge typecheck",
    "build:packages": "bash ./scripts/build-packages.sh",
    "patch:build": "bash ./scripts/build-packages.sh",
    "agent:patch:build": "bash ./scripts/build-packages.sh --agent",
    "city:patch:build": "bash ./scripts/build-packages.sh --city",
    "services:patch:build": "bash ./scripts/build-packages.sh --services",
    "plugins:patch:build": "bash ./scripts/build-packages.sh --plugins",
    "type:patch:build": "bash ./scripts/build-packages.sh --type",
    "cli:patch:build": "bash ./scripts/build-packages.sh --cli",
    "all:patch:build": "bash ./scripts/build-packages.sh --all"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git"
  },
  "homepage": "https://downcity.ai"
}

{
  "name": "@downcity/plugins",
  "version": "1.0.175",
  "type": "module",
  "description": "Downcity 内建 plugin 集合包",
  "main": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "exports": {
    ".": {
      "import": "./bin/index.js",
      "types": "./bin/index.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc && tsc-alias -f",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test:chat-access": "pnpm build && node --test scripts/chat-access.test.mjs",
    "test:chat-config": "pnpm build && node --test scripts/chat-channel-config.test.mjs",
    "prepack": "npm run build && node ../../scripts/rewrite-workspace-dependencies.mjs prepare ./package.json",
    "postpack": "node ../../scripts/rewrite-workspace-dependencies.mjs restore ./package.json"
  },
  "dependencies": {
    "@downcity/agent": "workspace:^",
    "@downcity/shell": "workspace:^",
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

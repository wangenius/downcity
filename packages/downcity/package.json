{
  "name": "downcity",
  "version": "1.0.496",
  "type": "module",
  "description": "每一个文件仓库都是一个Agent，搭建你的Agent City",
  "bin": {
    "downcity": "./bin/main/modules/cli/Index.js",
    "city": "./bin/main/modules/cli/Index.js"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('bin', { recursive: true, force: true })\" && tsc && tsc-alias -f && node scripts/copy-prompt-assets.mjs && node scripts/ensure-cli-executable.mjs",
    "dev": "tsc --watch",
    "start": "node bin/start.js",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "test:model": "npm run build && node --test test/model/create-model.test.mjs",
    "test:model:smoke": "node test/test-model.mjs",
    "typecheck": "tsc --noEmit",
    "lint:boundaries": "node scripts/lint-import-boundaries.mjs",
    "lint": "npm run lint:boundaries",
    "prepack": "npm run build"
  },
  "keywords": [
    "agent",
    "ai",
    "runtime",
    "telegram",
    "claude",
    "autonomous"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.28",
    "@ai-sdk/google": "^3.0.6",
    "@ai-sdk/huggingface": "^1.0.37",
    "@ai-sdk/moonshotai": "^2.0.10",
    "@ai-sdk/open-responses": "^1.0.6",
    "@ai-sdk/openai": "^3.0.21",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@ai-sdk/xai": "^3.0.67",
    "@larksuiteoapi/node-sdk": "^1.40.0",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.57",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.0",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.4",
    "execa": "^9.5.0",
    "fast-glob": "^3.3.0",
    "fs-extra": "^11.2.0",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.1.6",
    "node-cron": "^3.0.0",
    "openai": "^4.0.0",
    "ora": "^8.2.0",
    "prompts": "^2.4.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^5.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/prompts": "^2.4.0",
    "@types/ws": "^8.18.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.7.0"
  },
  "homepage": "https://downcity.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git"
  },
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  }
}

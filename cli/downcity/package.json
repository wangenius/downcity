{
  "name": "downcity",
  "version": "1.1.126",
  "type": "module",
  "description": "Downcity CLI bundle — installs city and town commands",
  "bin": {
    "city": "./bin/city/index.js",
    "town": "./bin/town/index.js"
  },
  "files": [
    "bin/",
    "city/",
    "town/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node scripts/copy-cli-products.mjs && node scripts/ensure-cli-executable.mjs",
    "dev": "node bin/city/index.js",
    "start": "node bin/city/index.js",
    "typecheck": "node scripts/verify-entry.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",

{
  "name": "@downcity/city",
  "version": "0.2.17",
  "description": "Downcity City runtime foundation for services, actions, auth, env, and studio-scoped gates.",
  "type": "module",
  "main": "./bin/index.js",
  "module": "./bin/index.js",
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "import": "./bin/index.js"
    }
  },
  "types": "./bin/index.d.ts",
  "files": [
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git",
    "directory": "packages/city"
  },
  "homepage": "https://downcity.ai",
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  },
  "keywords": [
    "downcity",
    "city",
    "ai",
    "runtime",
    "services"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "tsc && tsc -p tsconfig.test.json && node --test test/*.test.mjs",
    "prepack": "npm run build",
    "version:patch": "node ../../scripts/bump-package-version.mjs ./package.json"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "better-sqlite3": "^12.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "ai": "^6.0.168",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.1.0"
  }
}

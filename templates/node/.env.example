# Downcity Node 本地开发环境变量。
#
# 复制为 `.env` 后按需填写；不要把真实密钥提交到仓库。
# `npm run dev:node` 会自动加载本文件同级的 `.env`。

# 本地 dev 建议固定 bootstrap secret，避免每次重建数据库后 client 配置变化。
DOWNCITY_CITY_ADMIN_SECRET_KEY=admin_local_dev_secret
DOWNCITY_CITY_TOKEN_SIGNING_KEY=sign_local_dev_secret

# Node 模板当前使用 better-sqlite3，只支持 file: SQLite URL。
DOWNCITY_CITY_DATABASE_URL=file:./dev.db

# 本地 HTTP 监听地址。
HOST=127.0.0.1
PORT=43127

# DeepSeek via AI SDK + DeepSeek OpenAI-compatible API.
# 从 https://platform.deepseek.com/ 获取后填入本地 `.env`。
DEEPSEEK_API_KEY=sk-...

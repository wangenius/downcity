{
  "name": "downcity",
  "version": "1.1.205",
  "type": "module",
  "description": "Downcity CLI — unified City and Town management",
  "bin": {
    "city": "./bin/index.js",
    "downcity": "./bin/index.js",
    "downfed": "./bin/index.js",
    "fed": "./bin/index.js"
  },
  "files": [
    "bin/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc && tsc-alias -f && node scripts/ensure-cli-executable.mjs",
    "dev": "tsc --watch",
    "start": "node bin/index.js",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && node ../../scripts/rewrite-workspace-dependencies.mjs prepare ./package.json",
    "postpack": "node ../../scripts/rewrite-workspace-dependencies.mjs restore ./package.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/huggingface": "^1.0.50",
    "@ai-sdk/moonshotai": "^2.0.23",
    "@ai-sdk/open-responses": "^1.0.16",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/xai": "^3.0.93",
    "@downcity/agent": "workspace:^",
    "@downcity/city": "workspace:^",
    "@downcity/plugins": "workspace:^",
    "@downcity/server": "workspace:^",
    "@downcity/shell": "workspace:^",
    "@downcity/type": "workspace:*",
    "@earendil-works/pi-tui": "^0.74.2",
    "@larksuiteoapi/node-sdk": "^1.66.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "hono": "^4.12.23",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.11",
    "neo-blessed": "^0.2.0",
    "node-cron": "^4.2.1",
    "openai": "^6.39.1",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.18.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

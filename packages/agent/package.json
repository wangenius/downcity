{
  "name": "@downcity/agent",
  "version": "1.1.53",
  "type": "module",
  "description": "Downcity Agent 运行时 — 单 Agent 执行壳与 HTTP 服务能力",
  "main": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "exports": {
    ".": {
      "import": "./bin/index.js",
      "types": "./bin/index.d.ts"
    },
    "./internal/*": {
      "import": "./bin/*",
      "types": "./bin/*"
    }
  },
  "scripts": {
    "build": "node scripts/agent-compiler.mjs build",
    "dev": "node scripts/agent-compiler.mjs dev",
    "test:executor-runtime": "pnpm build && node --test scripts/session-prompt-runtime.test.mjs",
    "typecheck": "node scripts/agent-compiler.mjs typecheck"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.40.0",
    "ai": "^6.0.57",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "execa": "^9.5.0",
    "fs-extra": "^11.2.0",
    "hono": "^4.0.0",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.1.6",
    "node-cron": "^3.0.0",
    "ws": "^8.18.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/ws": "^8.18.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.7.0"
  }
}

{
  "name": "@downcity/ui",
  "version": "0.1.65",
  "description": "Downcity UI SDK for React and Tailwind CSS applications.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://downcity.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./source.css": "./src/source.css",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/source.css",
    "src/styles.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@pxlkit/core": "^1.3.3",
    "@pxlkit/effects": "^1.2.3",
    "@pxlkit/feedback": "^1.2.5",
    "@pxlkit/gamification": "^1.2.4",
    "@pxlkit/parallax": "^1.2.3",
    "@pxlkit/ui": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "downcity",
    "ui",
    "react",
    "tailwind",
    "agent"
  ]
}

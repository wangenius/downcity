{
  "name": "downcity-town-command",
  "version": "1.1.108",
  "private": true,
  "type": "module",
  "description": "Downcity Town CLI — 本机 Agent 宿主与运行入口",
  "bin": {
    "town": "./bin/index.js"
  },
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc && tsc-alias -f && node scripts/ensure-cli-executable.mjs",
    "dev": "tsc --watch",
    "start": "node bin/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@downcity/agent": "workspace:^",
    "@downcity/city": "workspace:^",
    "@downcity/plugins": "workspace:^",
    "@downcity/type": "workspace:*",
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "hono": "^4.12.23",
    "nanoid": "^5.1.11",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

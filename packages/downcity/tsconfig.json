{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./bin",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"],
      "@agent/*": ["./src/agent/*"],
      "@main/*": ["./src/main/*"],
      "@services/*": ["./src/services/*"],
      "@sessions/*": ["./src/sessions/*"],
      "@types/*": ["./src/types/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "bin"]
}

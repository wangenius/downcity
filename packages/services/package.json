{
  "name": "@downcity/services",
  "version": "0.1.175",
  "description": "Downcity public services package for accounts, balance, usage, Stripe, Creem, Dodo, and Waffo payment flows.",
  "type": "module",
  "main": "./bin/index.js",
  "module": "./bin/index.js",
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "import": "./bin/index.js"
    }
  },
  "types": "./bin/index.d.ts",
  "files": [
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git",
    "directory": "packages/services"
  },
  "homepage": "https://downcity.ai",
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  },
  "keywords": [
    "downcity",
    "service",
    "accounts",
    "balance",
    "usage",
    "stripe",
    "creem",
    "dodo",
    "waffo"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "tsc && tsc -p tsconfig.test.json && node --test $(find test -name \"*.test.mjs\")",
    "prepack": "npm run build && node ../../scripts/rewrite-workspace-dependencies.mjs prepare ./package.json",
    "postpack": "node ../../scripts/rewrite-workspace-dependencies.mjs restore ./package.json",
    "version:patch": "node ../../scripts/bump-package-version.mjs ./package.json"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "better-sqlite3": "^12.10.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@waffo/pancake-ts": "^0.11.0",
    "@downcity/city": "workspace:*",
    "better-auth": "^1.6.12",
    "dodopayments": "^2.36.0",
    "drizzle-orm": "^0.45.2"
  }
}

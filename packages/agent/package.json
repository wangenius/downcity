{
  "name": "@downcity/agent",
  "version": "1.1.242",
  "type": "module",
  "description": "Downcity Agent 运行时 — 单 Agent 执行壳与本机 RPC 能力",
  "main": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "exports": {
    ".": {
      "import": "./bin/index.js",
      "types": "./bin/index.d.ts"
    }
  },
  "scripts": {
    "build": "node scripts/agent-compiler.mjs build",
    "dev": "node scripts/agent-compiler.mjs dev",
    "test": "pnpm build && pnpm -C ../plugins build && node --test scripts/*.test.mjs",
    "test:executor-runtime": "pnpm build && node --test scripts/session-prompt-runtime.test.mjs",
    "typecheck": "node scripts/agent-compiler.mjs typecheck",
    "prepack": "npm run build && node ../../scripts/rewrite-workspace-dependencies.mjs prepare ./package.json",
    "postpack": "node ../../scripts/rewrite-workspace-dependencies.mjs restore ./package.json"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@downcity/shell": "workspace:^",
    "@downcity/type": "workspace:*",
    "ai": "^6.0.193",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "hono": "^4.12.23",
    "js-yaml": "^4.1.1",
    "nanoid": "^5.1.11",
    "node-cron": "^4.2.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

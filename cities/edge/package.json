{
  "name": "@downcity/city-edge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -C ../../packages/city build && pnpm -C ../../packages/services build",
    "dev": "wrangler dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "city deploy",
    "deploy:dry": "city deploy --dry-run",
    "deploy:verify": "city deploy --verify"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@downcity/city": "workspace:*",
    "@downcity/services": "workspace:*",
    "ai": "^6.0.193",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./bin",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"],
      "@city/*": ["./src/city/*"],
      "@main/*": ["./src/main/*"],
      "@session/*": ["./src/session/*"],
      "@shared/*": ["./src/shared/*"],
      "@services/*": ["./src/services/*"],
      "@sessions/*": ["./src/session/*"],
      "@types/*": ["./src/shared/types/*"],
      "@utils/*": ["./src/shared/utils/*"],
      "@/types/*": ["./src/shared/types/*"],
      "@/utils/*": ["./src/shared/utils/*"],
      "@/main/auth/*": ["./src/city/runtime/auth/*"],
      "@main/auth/*": ["./src/city/runtime/auth/*"],
      "@/main/constants/*": ["./src/shared/constants/*"],
      "@main/constants/*": ["./src/shared/constants/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "bin"]
}

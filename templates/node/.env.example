# Downcity Infra will add these on first server start if they are missing.
# Production deployments should set stable values in Dokploy / Compose env.
# DOWNCITY_CITY_ADMIN_SECRET_KEY=admin_xxx
# DOWNCITY_CITY_TOKEN_SIGNING_KEY=sign_xxx

# Optional: point the Node block at a custom SQLite file.
# cities/node currently supports file: SQLite URLs.
# DOWNCITY_CITY_DATABASE_URL=file:./data.sqlite

# Optional: bind host and port.
# HOST=127.0.0.1
# PORT=43127

# Kimi via AI SDK + Moonshot OpenAI-compatible API.
# Get it from https://platform.moonshot.ai/ and keep it only in your local .env.
# MOONSHOT_API_KEY=sk-...

# Kimi Code via AI SDK + Anthropic-compatible API.
# Get it from https://platform.kimi.ai/ and keep it only in your local .env.
# KIMI_CODE_API_KEY=sk-kimi-...

# DeepSeek via AI SDK + DeepSeek OpenAI-compatible API.
# Get it from https://platform.deepseek.com/ and keep it only in your local .env.
# DEEPSEEK_API_KEY=sk-...

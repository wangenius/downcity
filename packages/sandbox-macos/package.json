{
  "name": "@downcity/sandbox-macos",
  "version": "0.1.2",
  "type": "module",
  "description": "Downcity macOS Seatbelt sandbox adapter",
  "main": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "files": [
    "bin"
  ],
  "os": [
    "darwin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "import": "./bin/index.js"
    },
    "./*": {
      "types": "./bin/*",
      "import": "./bin/*"
    }
  },
  "scripts": {
    "build": "node ../../scripts/clean-package.mjs && tsc && tsc-alias -f",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node --test scripts/*.test.mjs",
    "prepack": "npm run build && node ../../scripts/rewrite-workspace-dependencies.mjs prepare ./package.json",
    "postpack": "node ../../scripts/rewrite-workspace-dependencies.mjs restore ./package.json",
    "version:patch": "node ../../scripts/bump-package-version.mjs ./package.json"
  },
  "license": "MIT",
  "dependencies": {
    "@downcity/shell": "workspace:^",
    "fs-extra": "^11.3.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

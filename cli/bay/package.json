{
  "name": "downcity-bay-command",
  "version": "1.1.61",
  "private": true,
  "type": "module",
  "description": "Downcity Bay CLI — 本机 Agent 宿主与运行入口",
  "bin": {
    "bay": "./bin/index.js"
  },
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc && tsc-alias -f && node scripts/ensure-cli-executable.mjs",
    "dev": "tsc --watch",
    "start": "node bin/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/huggingface": "^1.0.50",
    "@ai-sdk/moonshotai": "^2.0.23",
    "@ai-sdk/open-responses": "^1.0.16",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/xai": "^3.0.93",
    "@downcity/agent": "workspace:^",
    "@downcity/plugins": "workspace:^",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.193",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "nanoid": "^5.1.11",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

{
  "name": "@downcity/shell",
  "version": "0.1.125",
  "type": "module",
  "description": "Downcity Shell — structured file tools, local command execution, sandboxing, shell sessions, and approvals",
  "main": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "files": [
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git",
    "directory": "packages/shell"
  },
  "homepage": "https://downcity.ai",
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  },
  "keywords": [
    "downcity",
    "shell",
    "sandbox",
    "agent"
  ],
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "import": "./bin/index.js"
    },
    "./approval/*.js": {
      "types": "./bin/approval/*.d.ts",
      "import": "./bin/approval/*.js"
    },
    "./sandbox/*.js": {
      "types": "./bin/sandbox/*.d.ts",
      "import": "./bin/sandbox/*.js"
    },
    "./session/*.js": {
      "types": "./bin/session/*.d.ts",
      "import": "./bin/session/*.js"
    },
    "./tool/*.js": {
      "types": "./bin/tool/*.d.ts",
      "import": "./bin/tool/*.js"
    },
    "./types/*.js": {
      "types": "./bin/types/*.d.ts",
      "import": "./bin/types/*.js"
    },
    "./*": {
      "types": "./bin/*",
      "import": "./bin/*"
    }
  },
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc && tsc-alias -f",
    "dev": "tsc --watch",
    "test": "pnpm build && node --test scripts/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "version:patch": "node ../../scripts/bump-package-version.mjs ./package.json"
  },
  "license": "MIT",
  "dependencies": {
    "ai": "^6.0.193",
    "fs-extra": "^11.3.5",
    "globby": "^11.1.0",
    "node-pty": "1.2.0-beta.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}

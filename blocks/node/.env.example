# VisibleBase will add these on first server start:
# VISIBLEBASE_ADMIN_SECRET_KEY=admin_xxx
# VISIBLEBASE_TOKEN_SIGNING_KEY=sign_xxx

# Kimi via AI SDK + Moonshot OpenAI-compatible API.
# Get it from https://platform.moonshot.ai/ and keep it only in your local .env.
# MOONSHOT_API_KEY=sk-...

# Kimi Code via AI SDK + Anthropic-compatible API.
# Get it from https://platform.kimi.ai/ and keep it only in your local .env.
# KIMI_CODE_API_KEY=sk-kimi-...

# DeepSeek via AI SDK + DeepSeek OpenAI-compatible API.
# Get it from https://platform.deepseek.com/ and keep it only in your local .env.
# DEEPSEEK_API_KEY=sk-...

# Optional: point VisibleBase at a custom SQLite or Postgres database.
# VISIBLEBASE_DATABASE_URL=file:.visiblebase/visiblebase.sqlite

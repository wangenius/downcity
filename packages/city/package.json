{
  "name": "@downcity/city",
  "version": "0.2.25",
  "description": "Downcity City runtime and City access SDK for services, actions, auth, env, and towns.",
  "type": "module",
  "main": "./bin/index.js",
  "module": "./bin/index.js",
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "import": "./bin/index.js"
    }
  },
  "types": "./bin/index.d.ts",
  "files": [
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git",
    "directory": "packages/city"
  },
  "homepage": "https://downcity.ai",
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  },
  "keywords": [
    "downcity",
    "city",
    "ai",
    "runtime",
    "services"
  ],
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "tsc && tsc -p tsconfig.test.json && node --test test/*.test.mjs",
    "prepack": "npm run build",
    "version:patch": "node ../../scripts/bump-package-version.mjs ./package.json"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@downcity/type": "workspace:*",
    "ai": "^6.0.193",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./bin",
    "rootDir": "src",
    "baseUrl": "src",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["*"],
      "@downcity/agent": ["../../../packages/agent/bin/index.d.ts"],
      "@downcity/agent/internal/*": ["../../../packages/agent/bin/*"],
      "@downcity/type": ["../../../packages/type/bin/index.d.ts"]
    },
    "strict": true,
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "bin"]
}

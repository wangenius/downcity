{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./bin",
    "rootDir": "src",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@agent/*": ["agent/*"],
      "@main/*": ["main/*"],
      "@services/*": ["services/*"],
      "@sessions/*": ["sessions/*"],
      "@types/*": ["types/*"],
      "@utils/*": ["utils/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "bin"]
}

# Downcity Client 本地开发环境变量。
#
# 复制为 `.env` 后按需填写；不要把真实 token 提交到仓库。
# `npm run dev:client` 会自动加载本文件同级的 `.env`。

# 本地 Node City 地址，需要和 templates/node/.env 里的 HOST / PORT 对齐。
DOWNCITY_CLIENT_CITY_URL=http://127.0.0.1:43127

# 本地默认 town。City 初始化时会自动创建该 town。
DOWNCITY_CLIENT_TOWN_ID=town_downcity

# 本地调试用户 ID，用于自动签发 user_token。
DOWNCITY_CLIENT_USER_ID=dev_cli_user

# 本地开发 admin key。需要和 templates/node/.env 中的值保持一致。
# client 只在本地开发时用它自动签发 user_token。
DOWNCITY_CITY_ADMIN_SECRET_KEY=admin_local_dev_secret

# 可选：直接使用已有 user_token 时填这里；填了以后不会再用 admin key 自动签发。
# DOWNCITY_CLIENT_USER_TOKEN=

# 可选：指定模型 ID；不填则使用 City 的 text 默认模型。
# DOWNCITY_CLIENT_MODEL_ID=deepseek-v4-flash

# 可选：本地 Agent SDK 调试实例配置。
DOWNCITY_CLIENT_AGENT_ID=template_client
DOWNCITY_CLIENT_AGENT_PATH=.downcity/template-client

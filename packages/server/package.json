{
  "name": "@downcity/server",
  "version": "0.1.25",
  "type": "module",
  "description": "Downcity Server — Agent transport layer (RPC + HTTP) for @downcity/agent",
  "main": "./bin/index.js",
  "types": "./bin/index.d.ts",
  "files": [
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangenius/downcity.git",
    "directory": "packages/server"
  },
  "homepage": "https://downcity.ai",
  "bugs": {
    "url": "https://github.com/wangenius/downcity/issues"
  },
  "keywords": [
    "downcity",
    "agent",
    "rpc",
    "http"
  ],
  "exports": {
    ".": {
      "types": "./bin/index.d.ts",
      "import": "./bin/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf bin tsconfig.tsbuildinfo && tsc && tsc-alias -f",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && node ../../scripts/rewrite-workspace-dependencies.mjs prepare ./package.json",
    "postpack": "node ../../scripts/rewrite-workspace-dependencies.mjs restore ./package.json"
  },
  "license": "MIT",
  "dependencies": {
    "@downcity/agent": "workspace:^",
    "@downcity/shell": "workspace:^",
    "ai": "^6.0.193",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
